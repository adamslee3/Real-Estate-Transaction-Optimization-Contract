
{
  "name": "real-estate-transaction-optimization-contract",
  "version": "1.0.0",
  "description": "A comprehensive blockchain-based solution for streamlining real estate transactions through smart contracts built on the Stacks blockchain using Clarity.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:report": "vitest run -- --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "lint": "clarinet check",
    "deploy:devnet": "clarinet deploy --devnet",
    "deploy:testnet": "clarinet deploy --testnet"
  },
  "keywords": [
    "blockchain",
    "smart-contracts",
    "real-estate",
    "escrow",
    "stacks",
    "clarity",
    "property-management",
    "document-verification"
  ],
  "author": "Real Estate Smart Contract Team",
  "license": "MIT",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^2.3.2",
    "@stacks/transactions": "^6.12.0",
    "chokidar-cli": "^3.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vitest": "^1.3.1",
    "vitest-environment-clarinet": "^2.0.0"
  }
}
